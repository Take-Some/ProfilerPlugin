{
  "enabled": true,
  "ignore_self": true,
  "capture": {
    "service_calls": true,
    "plugin_lifecycle": true,
    "task_status_events": true,
    "custom_events": true
  },
  "budgets": {
    "service_call_ms": 8.0,
    "plugin_lifecycle_ms": 16.67,
    "custom_job_ms": 16.67,
    "task_status_ms": 16.67
  },
  "diagnostics": {
    "slow_job_warn_ms": 16.67,
    "stale_active_job_ms": 1000.0,
    "max_recent_jobs": 4096,
    "max_recent_diagnostics": 1024,
    "max_payload_preview_bytes": 2048
  },
  "report": {
    "write_on_shutdown": true,
    "write_json": true,
    "write_markdown": true,
    "directory": "cache/profiler",
    "latest_json": "profiler_report_latest.json",
    "latest_markdown": "profiler_report_latest.md",
    "write_archive": true,
    "include_latest_in_archive": true,
    "archive_prefix": "profiler_report",
    "write_csv": true,
    "latest_jobs_csv": "profiler_jobs_latest.csv",
    "latest_categories_csv": "profiler_categories_latest.csv",
    "latest_sources_csv": "profiler_sources_latest.csv",
    "latest_offenders_csv": "profiler_top_offenders_latest.csv",
    "latest_active_csv": "profiler_active_jobs_latest.csv",
    "latest_diagnostics_csv": "profiler_diagnostics_latest.csv",
    "latest_timeline_csv": "profiler_timeline_latest.csv"
  }
}
